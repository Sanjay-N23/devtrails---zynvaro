# ─────────────────────────────────────────────────────────────────
# Zynvaro — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── JWT Security (REQUIRED in production) ───────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-before-deploying

# ── OpenWeatherMap (Rain + Heatwave triggers) ────────────────────
# Free tier: 1,000 calls/day — register at https://openweathermap.org/api
# Enables LIVE rain and heatwave detection for all 7 cities.
OPENWEATHER_API_KEY=

# ── WAQI — World Air Quality Index (AQI trigger) ─────────────────
# Free token: https://aqicn.org/data-platform/token/
# Enables LIVE AQI readings for Mumbai, Delhi, Bangalore etc.
WAQI_API_TOKEN=

# ── Anthropic Claude (LLM Risk Explainer — Option C) ─────────────
# Free trial available at: https://console.anthropic.com/
# Enables AI-generated personalized risk narratives on /policies/risk-profile
# Without this key: falls back to rule-based template (still informative)
ANTHROPIC_API_KEY=

# ── Database (optional — defaults to SQLite zynvaro.db) ──────────
# Uncomment and set for PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/zynvaro
